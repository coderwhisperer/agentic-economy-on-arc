# Required: Gemini API key — get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required: Featherless API key — activate via the lablab promo link in the
# hackathon docs, then generate from your dashboard.
FEATHERLESS_API_KEY=

# Required: EVM private key for the BUYER wallet (signs gasless payment authorizations).
# This wallet needs testnet USDC. Get some at https://faucet.circle.com (select Arc Testnet).
# It also needs a small amount of testnet ETH/native gas for the ONE-TIME Gateway deposit tx.
PRIVATE_KEY=0x

# Required: EVM address that should receive USDC payments (your "merchant" wallet).
# Can be the same address as the buyer if you want a self-loop demo.
SELLER_ADDRESS=0x

# Optional: override the server URL the client points at
SERVER_URL=http://localhost:3000

# Optional: override these only if Circle publishes new addresses for Arc testnet.
# Source of truth: https://docs.arc.network/arc/references/contract-addresses
USDC_ARC_TESTNET=
GATEWAY_VERIFYING_CONTRACT=

# Optional: burst test tuning
BURST_N=100
BURST_CONCURRENCY=4

# Optional: server port
PORT=3000
